#!/usr/bin/env bash
set -euo pipefail

# ── Ensure PATH and HOME are set ────────────────────
if [[ -z "${HOME:-}" ]]; then
  export HOME="$(eval echo ~"$(id -un)")"
fi
export PATH="/opt/homebrew/bin:$HOME/.local/bin:$PATH"

# ── Helpers ─────────────────────────────────────────
resolve_path() {
  local clean
  clean=$(echo "$1" | sed $'s/\x1b[^m]*m//g' | sed $'s/\x1b([^)]*B//g' | sed 's/ ([^)]*)$//')
  if [[ "$clean" == ~* ]]; then
    echo "$HOME${clean:1}"
  else
    echo "$clean"
  fi
}

# ── Generate list (matches smart_workspace_switcher) ─
generate_list() {
  local session_names=""

  # 1. Existing zellij sessions first (like wezterm workspaces)
  if command -v zellij &>/dev/null; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name
      name=$(echo "$line" | awk '{print $1}')
      local status_label
      if [[ "$line" == *"(current)"* ]]; then
        status_label=" $(tput setaf 2)(current)$(tput sgr0)"
      elif [[ "$line" == *"EXITED"* ]]; then
        status_label=" $(tput setaf 1)(exited)$(tput sgr0)"
      else
        status_label=" $(tput setaf 3)(active)$(tput sgr0)"
      fi
      echo "󱂬 ${name}${status_label}"
      session_names="${session_names}:${name}:"
    done < <(zellij ls -n 2>/dev/null)
  fi

  # 2. All zoxide entries (no filtering — frecency handles ranking)
  while IFS= read -r dir; do
    [[ -z "$dir" ]] && continue
    local display="${dir/#$HOME/~}"
    local bname
    bname=$(basename "$dir")
    # Skip if already listed as a session
    if [[ "$session_names" == *":${bname}:"* ]]; then
      continue
    fi
    echo "$display"
  done < <(zoxide query -l 2>/dev/null)
}

# ── Session management (for fzf binds) ─────────────
clean_session_name() {
  echo "$1" | sed 's/^󱂬 //' | sed $'s/\x1b[^m]*m//g' | sed $'s/\x1b([^)]*B//g' | sed 's/ ([^)]*)$//' | awk '{print $1}'
}

if [[ "${1:-}" == "--delete" ]]; then
  session=$(clean_session_name "$2")
  zellij delete-session "$session" --force 2>/dev/null || true
  exit 0
fi

if [[ "${1:-}" == "--kill" ]]; then
  session=$(clean_session_name "$2")
  zellij kill-session "$session" 2>/dev/null || true
  exit 0
fi

if [[ "${1:-}" == "--list" ]]; then
  generate_list
  exit 0
fi

# ── Main: fzf picker ───────────────────────────────
selected=$(generate_list | fzf --ansi \
  --prompt="  session: " \
  --header="enter: attach | ctrl-d: delete | ctrl-k: kill" \
  --bind="ctrl-d:execute-silent($0 --delete {})+reload($0 --list)" \
  --bind="ctrl-k:execute-silent($0 --kill {})+reload($0 --list)") || exit 1

# ── Resolve selection ──────────────────────────────
if [[ "$selected" == 󱂬\ * ]]; then
  # Session entry — extract name
  session_name=$(clean_session_name "$selected")
  dir=""
else
  # Zoxide path entry
  dir=$(resolve_path "$selected")
  session_name=$(basename "$dir")
  # Boost zoxide score
  zoxide add "$dir" 2>/dev/null || true
fi

# ── Attach or switch ───────────────────────────────
if [[ -n "${ZELLIJ:-}" ]]; then
  # Track current session for last-session toggle
  mkdir -p "$HOME/.cache/zellij"
  echo -n "${ZELLIJ_SESSION_NAME:-}" > "$HOME/.cache/zellij/.session-state.last"

  if [[ -n "$dir" ]] && ! zellij ls -n 2>/dev/null | grep -q "^$session_name "; then
    (cd "$dir" && ZELLIJ="" zellij attach "$session_name" --create-background) 2>/dev/null
  fi
  zellij action switch-session "$session_name"
else
  if [[ -n "$dir" ]]; then
    cd "$dir" && zellij attach --create "$session_name"
  else
    zellij attach "$session_name"
  fi
fi
